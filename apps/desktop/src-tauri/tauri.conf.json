{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PARITY",
  "version": "0.1.0",
  "identifier": "com.parity.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @parity/web dev",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "pnpm --filter @parity/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "desktop",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
