{
  "expo": {
    "name": "Parity Finance",
    "slug": "parity-finance",
    "version": "2.0.0",
    "orientation": "portrait",
    "scheme": "parity",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.metalsyntax.parity",
      "associatedDomains": [
        "applinks:parity.finance",
        "applinks:parity.finance"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Scan receipts and invoices",
        "NSFaceIDUsageDescription": "Authenticate with Face ID",
        "NSUserDefaultsSuite": "group.com.metalsyntax.parity",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#050505"
      },
      "package": "com.metalsyntax.parity",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "parity.finance",
              "pathPrefix": "/"
            },
            {
              "scheme": "parity"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Parity to scan receipts."
        }
      ],
      "expo-sqlite",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Parity to authenticate with Face ID"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0dc93b13-eaa3-437c-bb02-3a3856015288"
      }
    }
  }
}
