{
  "name": "parity-monorepo",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=@parity/web",
    "desktop:dev": "pnpm --filter @parity/desktop dev",
    "desktop:build": "pnpm --filter @parity/desktop build",
    "desktop:install": "pnpm --filter @parity/desktop install-app",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "20.x"
  }
}
