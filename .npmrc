# Hoist React Native / Expo packages to root node_modules so Gradle scripts
# can resolve them via standard node resolution (pnpm virtual store breaks this).
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=@expo*
public-hoist-pattern[]=@babel*
public-hoist-pattern[]=@react-navigation*
public-hoist-pattern[]=metro*
public-hoist-pattern[]=hermes*
